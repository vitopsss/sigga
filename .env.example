# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# SIGGATER isolated app scope
SIGGA_APP_SCOPE=siggater
NEXT_PUBLIC_SIGGA_APP_SCOPE=siggater

# Session signing secret. Use a strong random value with at least 32 characters.
SIGGATER_SESSION_SECRET="replace-with-a-strong-random-secret"
