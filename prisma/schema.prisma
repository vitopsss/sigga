// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS DE DOMÍNIO (Atualizado conf. Relatório Beto)
// ============================================================================
enum Role {
  ADMINISTRADOR_DIRETOR // Acesso a parametrização e dados sensíveis
  GERENTE               // Visão tática ampla sobre todos os módulos
  COORDENADOR_PROJETO   // Visão operacional, relatórios e filtros específicos
  OPERADOR              // Trabalho de campo, inserção de dados, antigo '"'"'extensionista'"'"'
}

enum TipoCadastro {
  PF        // Pessoa Física
  PJ        // Pessoa Jurídica
  PUBLICO   // Público
  PRIVADO   // Privado
}

// ============================================================================
// 0. PESSOAS (cadastro básico - criado pelo fix_banco)
// ============================================================================

model Pessoa {
  id               String       @id @default(dbgenerated("gen_random_uuid()"))
  tipo           String   @default("PF")
  documento      String   @unique
  nome           String
  email          String?
  telefone       String?
  endereco       String?
  bairro         String?
  cidade         String?
  estado         String?
  cep            String?
  pais           String?
  banco          String?
  agencia        String?
  conta          String?
  pix            String?
  origemCadastro String   @default("INTERNO")
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("pessoas")
  @@index([documento])
}

// ============================================================================
// 1. NÚCLEO E ACESSO (O "Cadastro Único")
// ============================================================================

model CadastroUnico {
  id               String   @id @default(uuid())
  tipo             TipoCadastro
  documento        String   @unique // CPF / CNPJ
  nome             String // NOME / RAZÃO SOCIAL

  // Dados exigidos pelo Beto para entrada externa
  email            String?
  telefone         String?
  endereco         String?
  documentosAnexos Boolean  @default(false) // Flag indicando se a pessoa fez upload de CNH/Contrato
  origemCadastro   String   @default("INTERNO") // Pode ser "LINK_EXTERNO", "INTERNO"

  // Dados Bancários
  banco            String?
  agencia          String?
  conta            String?
  pix              String?

  usuario          User?
  colaborador      Colaborador?
  beneficiaria     Beneficiaria?
  familia          FamiliaAter?
  empreendimento   Empreendimento?
  borderos         LancamentoFinanceiro[]
  contratos        ContratoFornecedor[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cadastros_unicos")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  passwordHash  String?   // Para login seguro
  role          Role      @default(OPERADOR) // A hierarquia exigida pelo Beto
  status        String    @default("ATIVO")
  perfilId      String?

  cadastroId    String?   @unique
  cadastro      CadastroUnico? @relation(fields: [cadastroId], references: [id])

  @@map("users")
}

// ============================================================================
// 2. GESTÃO DE PROJETOS E ORÇAMENTO (Abas B1, B2, B3, B4)
// ============================================================================

model Projeto {
  id                 String   @id @default(uuid())
  centroCusto        String   @unique // ID C. DE CUSTO (Ex: 1084)
  ano                Int?
  status             String
  portfolio          String?
  titulo             String
  abreviacao         String?
  financiador        String?
  numContrato        String?  // Nº DO CONTRATO/CONVÊNIO
  valorTotal         Decimal  @db.Decimal(15, 2)
  vigenciaInicial    DateTime
  vigenciaFinal      DateTime?

  // Relações
  orcamentos         OrcamentoItem[]
  faturamentos       FaturamentoProjeto[]
  borderos           Bordero[]
  alocacoesRH        ColaboradorProjeto[]
  atividadesATER     PlanejamentoAtividade[]
  projetosProdutivos ProjetoProdutivo[]

  @@map("projetos")
}

model OrcamentoItem {
  id              String   @id @default(uuid())
  idOrc           String   @unique // IDORC
  planoGerencial  String?  // PLANO GERENCIAL
  descricao       String?
  unidade         String?
  quantidade      Int?
  valorReferencia Decimal  @db.Decimal(15, 2)
  valorTotal      Decimal  @db.Decimal(15, 2)

  projetoId       String
  projeto         Projeto  @relation(fields: [projetoId], references: [id])

  @@map("orcamentos_itens")
}

// ============================================================================
// 3. FINANCEIRO E FATURAMENTO (Abas F1, F2, F3)
// ============================================================================

model FaturamentoProjeto {
  id                String    @id @default(uuid())
  parcela           Int?
  vencimento        DateTime?
  valorTotal        Decimal   @db.Decimal(15, 2)
  dataLiquidacao    DateTime?
  numNotaFiscal     String?   // Nº DE CONTROLE NF

  projetoId         String
  projeto           Projeto   @relation(fields: [projetoId], references: [id])

  @@map("faturamentos_projetos")
}

model Bordero {
  id              String    @id @default(uuid())
  idBordero       String    @unique // IDBOR (Ex: BOR100546)
  data            DateTime? @default(now())
  cadastrador     String?
  tipoBordero     String?   // Pagar ou Receber
  status          String    @default("Pendente")

  projetoId       String
  projeto         Projeto   @relation(fields: [projetoId], references: [id])
  lancamentos     LancamentoFinanceiro[]

  @@map("borderos")
}

model LancamentoFinanceiro {
  id                String    @id @default(uuid())
  nsu               String    @unique // NSU
  fase              String?
  etapa             String?
  atividade         String?
  valor             Decimal   @db.Decimal(15, 2)
  dataVencimento    DateTime

  // Fluxo de Caixa / Tesouraria
  autorizado        Boolean   @default(false)
  conciliado        Boolean   @default(false)
  dataPagamento     DateTime?
  formaPagamento    String?

  borderoId         String
  bordero           Bordero   @relation(fields: [borderoId], references: [id], onDelete: Cascade)

  favorecidoId      String
  favorecido        CadastroUnico @relation(fields: [favorecidoId], references: [id])

  @@map("lancamentos_financeiros")
}

// ============================================================================
// 4. RECURSOS HUMANOS (Abas D1, D2)
// ============================================================================

model Colaborador {
  id              String   @id @default(uuid())
  idRH            String   @unique // IDRH
  cargo           String?
  vinculo         String?  // Celetista, Bolsista
  salarioBase     Decimal  @db.Decimal(15, 2)
  status          String?

  cadastroId      String   @unique
  cadastro        CadastroUnico @relation(fields: [cadastroId], references: [id])
  alocacoes       ColaboradorProjeto[]

  @@map("colaboradores")
}

model ColaboradorProjeto {
  id            String      @id @default(uuid())
  porcentagem   Decimal     @db.Decimal(5, 2) @default(100.00)
  colaboradorId String
  projetoId     String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])
  projeto       Projeto     @relation(fields: [projetoId], references: [id])

  @@map("colaboradores_projetos")
}

// ============================================================================
// 5. MÓDULO TÉCNICO ATER E SGA (Abas AT, RELATAT, TEC 2026)
// ============================================================================

// ---------------------------------------------------------------------------
// 5a. ATER Sociobio — Beneficiária (mulheres) — LEGADO preservado
// ---------------------------------------------------------------------------

model Beneficiaria {
  id                       String   @id @default(uuid())
  codigoSGA                String?  @unique // ID SGA
  nis                      String?  @unique
  municipio                String?
  comunidade               String?
  ufpa                     String?  // Unidade Familiar de Produção Agrária
  grupoInteresse           String?
  statusCadastro           String?
  situacaoProjeto          String?
  tipoAtendimento          String?
  atividadeProdutiva       String?
  projetoColetivoPrincipal String?
  valorProjetoATER         Decimal? @db.Decimal(15, 2)
  valorInvestidoUFPA       Decimal? @db.Decimal(15, 2)
  efetividade              String?
  houveAvanco              Boolean?
  sgaCadastro              Boolean?
  sgaRevisao               Boolean?
  sgaIndicador             Boolean?
  sgaFotos                 Boolean?
  statusSGA                String?
  ajusteProjeto            String?
  informacaoSGA            String?
  envioSGAPorAtividade     Json?

  cadastroId      String   @unique
  cadastro        CadastroUnico @relation(fields: [cadastroId], references: [id])

  atendimentos        AtendimentoTecnico[]
  atendimentosATER   Atendimento[]
  controleSGA         ControleProcessoSGA?
  fomento             Fomento?

  @@map("beneficiarias")
}

// ---------------------------------------------------------------------------
// 5b. ATER Socio — Família (novo módulo, orientado a família)
// ---------------------------------------------------------------------------

model FamiliaAter {
  id                 String   @id @default(uuid())
  nomeFamilia        String
  nomeResponsavel    String?
  documentoResponsavel String?  // CPF do responsável pela família
  telefone           String?
  quantidadeMembros  Int?
  composicaoFamiliar Json?    // [{nome, parestesco, dataNascimento}]
  municipio          String?
  comunidade         String?
  ufpa               String?  // Unidade Familiar de Produção Agrária
  grupoInteresse     String?
  statusCadastro     String?
  situacaoProjeto    String?
  tipoAtendimento    String?
  atividadeProdutiva String?
  projetoColetivoPrincipal String?
  valorProjetoATER   Decimal? @db.Decimal(15, 2)
  valorInvestidoUFPA Decimal? @db.Decimal(15, 2)
  efetividade        String?
  houveAvanco        Boolean?
  nis                String?
  codigoSGA          String?
  sgaCadastro        Boolean?
  sgaRevisao         Boolean?
  sgaIndicador       Boolean?
  sgaFotos           Boolean?
  statusSGA          String?
  ajusteProjeto      String?
  informacaoSGA      String?
  envioSGAPorAtividade Json?
  situacaoFomento    String?
  valorFomento       Decimal? @db.Decimal(15, 2)
  sgaStatusAnalise   String?
  sgaParcela1        String?
  sgaParcela2        String?
  sgaProjetoEnviado  Boolean  @default(false)

  cadastroId String   @unique
  cadastro   CadastroUnico @relation(fields: [cadastroId], references: [id])

  atendimentos Atendimento[]

  @@map("familias_ater")
}

model AtendimentoTecnico {
  id                String   @id @default(uuid())
  idTec             String   @unique // ID TEC (Ex: AT7OR241)
  data              DateTime @default(now())
  tecnico           String

  // Eixo Produtivo
  produtivoAcao     String?
  produtivoImpacto  String? @db.Text

  // Eixo Social
  socialAcao        String?
  socialImpacto     String? @db.Text

  // Eixo Ambiental
  ambientalAcao     String?
  ambientalImpacto  String? @db.Text

  beneficiariaId    String
  beneficiaria      Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("atendimentos_tecnicos")
}

model Atendimento {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numeroVisita     Int
  data             DateTime?    @db.Timestamptz(6)
  tecnico          String?
  projetoId        String?
  projetoTitulo    String?
  statusRelatorio  String       @default("PENDENTE")
  houveAtendimento Boolean?
  enviadoSGA       Boolean      @default(false)
  dataEnvioSGA     DateTime?    @db.Timestamptz(6)
  eixoProdutivo    Json?
  eixoSocial       Json?
  eixoAmbiental    Json?
  tecnicoId        String?
  beneficiariaId   String?
  beneficiaria     Beneficiaria? @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)
  familiaId        String?
  familia          FamiliaAter? @relation(fields: [familiaId], references: [id])
  tecnicoRef       Tecnico?     @relation(fields: [tecnicoId], references: [id])

  @@index([beneficiariaId], map: "atendimentos_beneficiaria_idx")
  @@index([numeroVisita])
  @@index([tecnicoId], map: "atendimentos_tecnico_idx")
  @@index([familiaId], map: "atendimentos_familia_idx")
  @@map("atendimentos")
}

model Tecnico {
  id               String       @id @default(dbgenerated("gen_random_uuid()"))
  nome             String
  cpf              String       @unique
  registroConselho String?
  uf               String?
  ativo            Boolean      @default(true)

  atendimentos    Atendimento[]

  @@index([cpf])
  @@map("tecnicos_ater")
}

model Fomento {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  situacao       String?
  valorFomento   Decimal?  @db.Decimal(15, 2)
  valorInvestido Decimal?  @db.Decimal(15, 2)
  retornoCampo   String?
  orientacoes    String?
  analiseAnater  String?
  beneficiariaId String    @unique
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)

  @@index([beneficiariaId], map: "fomentos_beneficiaria_idx")
  @@map("fomentos")
}

model ControleProcessoSGA {
  id                String   @id @default(uuid())
  statusAnalise     String?  // Situação da Analise
  parcela1          String?  // Parcela nº 1
  parcela2          String?  // Parcela nº 2
  projetoEnviado    Boolean  @default(false)

  beneficiariaId    String   @unique
  beneficiaria      Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("controle_sga")
}

model PlanejamentoAtividade {
  id                String   @id @default(uuid())
  numMeta           Int
  descricao         String
  status            String   // Em execução, Não iniciado
  valorUnitario     Decimal  @db.Decimal(15, 2)

  projetoId         String
  projeto           Projeto  @relation(fields: [projetoId], references: [id])

  @@map("planejamento_ater")
}

model ProjetoProdutivo {
  id                String   @id @default(uuid())
  atividade         String   // SAF, Avicultura, etc.
  situacao          String?  // Ativo, Inativo

  projetoId         String
  projeto           Projeto @relation(fields: [projetoId], references: [id])

  @@map("projetos_produtivos")
}

// ============================================================================
// 6. COMPRAS E PATRIMÓNIO (Abas C1, C3, E1)
// ============================================================================

model ContratoFornecedor {
  id              String   @id @default(uuid())
  idContrato      String   @unique // ID CONTRATO
  objeto          String?  @db.Text
  valorTotal      Decimal  @db.Decimal(15, 2)
  status          String?

  fornecedorId    String
  fornecedor      CadastroUnico @relation(fields: [fornecedorId], references: [id])

  @@map("contratos_fornecedores")
}

model Patrimonio {
  id              String   @id @default(uuid())
  tombamento      String?  @unique // N. Tombamento
  descricao       String
  status          String?  // Baixado, Em uso
  valorAquisicao  Decimal? @db.Decimal(15, 2)

  @@map("patrimonio")
}

// ============================================================================
// 7. GESTÃO DE FUNDOS E EMPREENDIMENTOS (Antigo SISREDE)
// ============================================================================

model Empreendimento {
  id              String   @id @default(uuid())
  matricula       String?  @unique // MATRÍCULA SISREDE (Ex: 20002)
  nome            String   // Nome do Empreendimento (Magia Amazônica, etc)
  segmento        String?  // Agroecológico, Artesanato, Processados...
  status          String?  @default("ATIVO")

  // O Dono do Empreendimento vem do Cadastro Único
  cadastroId      String   @unique
  cadastro        CadastroUnico @relation(fields: [cadastroId], references: [id])

  contribuicoes   ContribuicaoFundo[]

  @@map("empreendimentos")
}

model ContribuicaoFundo {
  id              String   @id @default(uuid())
  parcela         String?  // Ex: "1/10", "2/10" (Aba Carnê)
  mesReferencia   Int?
  anoReferencia   Int?
  valorGerado     Decimal  @db.Decimal(15, 2) // Valor calculado/orçado
  valorPago       Decimal? @db.Decimal(15, 2) // Valor real pago
  dataVencimento  DateTime?
  dataPagamento   DateTime?
  status          String   @default("PENDENTE") // PAGO, PENDENTE, ATRASADO

  empreendimentoId String
  empreendimento  Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@map("contribuicoes_fundo")
}
