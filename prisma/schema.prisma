  qtdAves                   Int?
  qtdBubalinos              Int?
  qtdEquinosMuaresAsininos  Int?
  qtdColmeias               Int?
  qtdPequenosAnimaisOutros  Int?
  areaPastagens             Decimal?  @db.Decimal(12, 2)
  areaCulturasTemporarias   Decimal?  @db.Decimal(12, 2)
  areaCulturasPermanentes   Decimal?  @db.Decimal(12, 2)
  areaLaminaAgua            Decimal?  @db.Decimal(12, 2)
  areaExtrativismo          Decimal?  @db.Decimal(12, 2)
  areaReservaLegal          Decimal?  @db.Decimal(12, 2)
  areaOutrosUsos            Decimal?  @db.Decimal(12, 2)
  recursosDisponiveis       Json?
  atividadesColetivas       Json?
  politicasPublicas         Json?
  acoesPotenciaisProdutivo  String?   @db.Text
  acoesPotenciaisSocial     String?   @db.Text
