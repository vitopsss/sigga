model AtendimentoTecnico {
  id      String   @id @default(uuid())
  idTec   String   @unique // ID TEC (Ex: AT7OR241)
  data    DateTime @default(now())
  tecnico String

  // Eixo Produtivo
  produtivoAcao    String?
  produtivoImpacto String? @db.Text

  // Eixo Social
  socialAcao    String?
  socialImpacto String? @db.Text

  // Eixo Ambiental
  ambientalAcao    String?
  ambientalImpacto String? @db.Text

  beneficiariaId String
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("atendimentos_tecnicos")
}

model Atendimento {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numeroVisita     Int
  data             DateTime?     @db.Timestamptz(6)
  tecnico          String?
  projetoId        String?
  projetoTitulo    String?
  statusRelatorio  String        @default("PENDENTE")
  houveAtendimento Boolean?
  enviadoSGA       Boolean       @default(false)
  dataEnvioSGA     DateTime?     @db.Timestamptz(6)
  atividadeNumeroTotal String?
  codigoMeta       String?
  descricaoMeta    String?       @db.Text
  numeroMulheres   Int?
  numeroJovens     Int?
  statusGestor     String?
  motivoReprovacaoGestor String? @db.Text
  dataStatusGestor DateTime?     @db.Timestamptz(6)
  eixoProdutivo    Json?
  eixoSocial       Json?
  eixoAmbiental    Json?
  tecnicoId        String?
  beneficiariaId   String?
  beneficiaria     Beneficiaria? @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)
  familiaId        String?
  familia          FamiliaAter?  @relation(fields: [familiaId], references: [id])
  tecnicoRef       Tecnico?      @relation(fields: [tecnicoId], references: [id])

  @@index([beneficiariaId], map: "atendimentos_beneficiaria_idx")
  @@index([numeroVisita])
  @@index([tecnicoId], map: "atendimentos_tecnico_idx")
  @@index([familiaId], map: "atendimentos_familia_idx")
  @@map("atendimentos")
}

model Tecnico {
  id               String  @id @default(dbgenerated("gen_random_uuid()"))
  nome             String
  cpf              String  @unique
  conselho         String? // Ex: CREA, CRMV, CRF
  registroConselho String?
  uf               String?
  ativo            Boolean @default(true)

  atendimentos Atendimento[]

  @@index([cpf])
  @@map("tecnicos_ater")
}

model Fomento {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  situacao       String?
  valorFomento   Decimal?     @db.Decimal(15, 2)
  valorInvestido Decimal?     @db.Decimal(15, 2)
  retornoCampo   String?
  orientacoes    String?
  analiseAnater  String?
  beneficiariaId String       @unique
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)

  @@index([beneficiariaId], map: "fomentos_beneficiaria_idx")
  @@map("fomentos")
}

model ControleProcessoSGA {
  id             String  @id @default(uuid())
  statusAnalise  String? // Situação da Analise
  parcela1       String? // Parcela nº 1
  parcela2       String? // Parcela nº 2
  projetoEnviado Boolean @default(false)

  beneficiariaId String       @unique
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("controle_sga")
}

model PlanejamentoAtividade {
  id            String  @id @default(uuid())
  numMeta       Int
  descricao     String
  status        String // Em execução, Não iniciado
  valorUnitario Decimal @db.Decimal(15, 2)

  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id])

  @@map("planejamento_ater")
}

model ProjetoProdutivo {
  id        String  @id @default(uuid())
  atividade String // SAF, Avicultura, etc.
  situacao  String? // Ativo, Inativo

  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id])

  @@map("projetos_produtivos")
}

// ============================================================================
// 6. COMPRAS E PATRIMÓNIO (Abas C1, C3, E1)
// ============================================================================

model ContratoFornecedor {
  id         String  @id @default(uuid())
  idContrato String  @unique // ID CONTRATO
  objeto     String? @db.Text
  valorTotal Decimal @db.Decimal(15, 2)
  status     String?

  fornecedorId String
  fornecedor   CadastroUnico @relation(fields: [fornecedorId], references: [id])

  @@map("contratos_fornecedores")
}

model Patrimonio {
  id             String   @id @default(uuid())
  tombamento     String?  @unique // N. Tombamento
  descricao      String
  status         String? // Baixado, Em uso
  valorAquisicao Decimal? @db.Decimal(15, 2)

  @@map("patrimonio")
}

// ============================================================================
// 7. GESTÃO DE FUNDOS E EMPREENDIMENTOS (Antigo SISREDE)
// ============================================================================

model Empreendimento {
  id        String  @id @default(uuid())
  matricula String? @unique // MATRÍCULA SISREDE (Ex: 20002)
  nome      String // Nome do Empreendimento (Magia Amazônica, etc)
  segmento  String? // Agroecológico, Artesanato, Processados...
  status    String? @default("ATIVO")

  // O Dono do Empreendimento vem do Cadastro Único
  cadastroId String        @unique
  cadastro   CadastroUnico @relation(fields: [cadastroId], references: [id])

  contribuicoes ContribuicaoFundo[]

  @@map("empreendimentos")
}

model ContribuicaoFundo {
  id             String    @id @default(uuid())
  parcela        String? // Ex: "1/10", "2/10" (Aba Carnê)
  mesReferencia  Int?
  anoReferencia  Int?
  valorGerado    Decimal   @db.Decimal(15, 2) // Valor calculado/orçado
  valorPago      Decimal?  @db.Decimal(15, 2) // Valor real pago
  dataVencimento DateTime?
  dataPagamento  DateTime?
  status         String    @default("PENDENTE") // PAGO, PENDENTE, ATRASADO

  empreendimentoId String
  empreendimento   Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@map("contribuicoes_fundo")
}
