// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS DE DOMÍNIO (Atualizado conf. Relatório Beto)
// ============================================================================
enum Role {
  ADMINISTRADOR_DIRETOR // Acesso a parametrização e dados sensíveis
  GERENTE // Visão tática ampla sobre todos os módulos
  COORDENADOR_PROJETO // Visão operacional, relatórios e filtros específicos
  OPERADOR // Trabalho de campo, inserção de dados, antigo '"'"'extensionista'"'"'
}

enum TipoCadastro {
  PF // Pessoa Física
  PJ // Pessoa Jurídica
  PUBLICO // Público
  PRIVADO // Privado
}

// ============================================================================
// 0. PESSOAS (cadastro básico - criado pelo fix_banco)
// ============================================================================

model Pessoa {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  tipo           String   @default("PF")
  documento      String   @unique
  nome           String
  email          String?
  telefone       String?
  endereco       String?
  bairro         String?
  cidade         String?
  estado         String?
  cep            String?
  pais           String?
  banco          String?
  agencia        String?
  conta          String?
  pix            String?
  origemCadastro String   @default("INTERNO")
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([documento])
  @@map("pessoas")
}

// ============================================================================
// 1. NÚCLEO E ACESSO (O "Cadastro Único")
// ============================================================================

model CadastroUnico {
  id        String       @id @default(uuid())
  tipo      TipoCadastro
  documento String       @unique // CPF / CNPJ
  nome      String // NOME / RAZÃO SOCIAL

  // Dados exigidos pelo Beto para entrada externa
  email            String?
  telefone         String?
  endereco         String?
  documentosAnexos Boolean @default(false) // Flag indicando se a pessoa fez upload de CNH/Contrato
  origemCadastro   String  @default("INTERNO") // Pode ser "LINK_EXTERNO", "INTERNO"

  // Dados Bancários
  banco   String?
  agencia String?
  conta   String?
  pix     String?

  usuario        User?
  colaborador    Colaborador?
  beneficiaria   Beneficiaria?
  familia        FamiliaAter?
  empreendimento Empreendimento?
  borderos       LancamentoFinanceiro[]
  contratos      ContratoFornecedor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cadastros_unicos")
}

model User {
  id           String  @id @default(uuid())
  name         String?
  email        String? @unique
  passwordHash String? // Para login seguro
  role         Role    @default(OPERADOR) // A hierarquia exigida pelo Beto
  status       String  @default("ATIVO")
  perfilId     String?

  cadastroId String?        @unique
  cadastro   CadastroUnico? @relation(fields: [cadastroId], references: [id])

  @@map("users")
}

// ============================================================================
// 2. GESTÃO DE PROJETOS E ORÇAMENTO (Abas B1, B2, B3, B4)
// ============================================================================

model Projeto {
  id              String    @id @default(uuid())
  centroCusto     String    @unique // ID C. DE CUSTO (Ex: 1084)
  ano             Int?
  status          String
  portfolio       String?
  titulo          String
  abreviacao      String?
  financiador     String?
  numContrato     String? // Nº DO CONTRATO/CONVÊNIO
  valorTotal      Decimal   @db.Decimal(15, 2)
  vigenciaInicial DateTime
  vigenciaFinal   DateTime?

  // Relações
  orcamentos         OrcamentoItem[]
  faturamentos       FaturamentoProjeto[]
  borderos           Bordero[]
  alocacoesRH        ColaboradorProjeto[]
  atividadesATER     PlanejamentoAtividade[]
  projetosProdutivos ProjetoProdutivo[]

  @@map("projetos")
}

model OrcamentoItem {
  id              String  @id @default(uuid())
  idOrc           String  @unique // IDORC
  planoGerencial  String? // PLANO GERENCIAL
  descricao       String?
  unidade         String?
  quantidade      Int?
  valorReferencia Decimal @db.Decimal(15, 2)
  valorTotal      Decimal @db.Decimal(15, 2)

  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id])

  @@map("orcamentos_itens")
}

// ============================================================================
// 3. FINANCEIRO E FATURAMENTO (Abas F1, F2, F3)
// ============================================================================

model FaturamentoProjeto {
  id             String    @id @default(uuid())
  parcela        Int?
  vencimento     DateTime?
  valorTotal     Decimal   @db.Decimal(15, 2)
  dataLiquidacao DateTime?
  numNotaFiscal  String? // Nº DE CONTROLE NF

  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id])

  @@map("faturamentos_projetos")
}

model Bordero {
  id          String    @id @default(uuid())
  idBordero   String    @unique // IDBOR (Ex: BOR100546)
  data        DateTime? @default(now())
  cadastrador String?
  tipoBordero String? // Pagar ou Receber
  status      String    @default("Pendente")

  projetoId   String
  projeto     Projeto                @relation(fields: [projetoId], references: [id])
  lancamentos LancamentoFinanceiro[]

  @@map("borderos")
}

model LancamentoFinanceiro {
  id        String  @id @default(uuid())
  nsu       String  @unique // NSU
  fase      String?
  etapa     String?
  atividade String?

  // Classificação Operacional (46k)
  idPgc      String? // Identificador do Plano Gerencial de Custos (Passivo)
  idOrc      String? // Identificador do Orçamento (Passivo)
  observacao String? @db.Text // Campo de observação estruturada

  valor          Decimal  @db.Decimal(15, 2)
  dataVencimento DateTime

  // Fluxo de Caixa / Tesouraria
  autorizado     Boolean   @default(false)
  conciliado     Boolean   @default(false)
  dataPagamento  DateTime?
  formaPagamento String?

  borderoId String
  bordero   Bordero @relation(fields: [borderoId], references: [id], onDelete: Cascade)

  favorecidoId String
  favorecido   CadastroUnico @relation(fields: [favorecidoId], references: [id])

  @@map("lancamentos_financeiros")
}

// ============================================================================
// 4. RECURSOS HUMANOS (Abas D1, D2)
// ============================================================================

model Colaborador {
  id          String  @id @default(uuid())
  idRH        String  @unique // IDRH
  cargo       String?
  vinculo     String? // Celetista, Bolsista
  salarioBase Decimal @db.Decimal(15, 2)
  status      String?

  cadastroId String               @unique
  cadastro   CadastroUnico        @relation(fields: [cadastroId], references: [id])
  alocacoes  ColaboradorProjeto[]

  @@map("colaboradores")
}

model ColaboradorProjeto {
  id            String      @id @default(uuid())
  porcentagem   Decimal     @default(100.00) @db.Decimal(5, 2)
  colaboradorId String
  projetoId     String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])
  projeto       Projeto     @relation(fields: [projetoId], references: [id])

  @@map("colaboradores_projetos")
}

// ============================================================================
// 5. MÓDULO TÉCNICO ATER E SGA (Abas AT, RELATAT, TEC 2026)
// ============================================================================

// ---------------------------------------------------------------------------
// 5a. ATER Sociobio — Beneficiária (mulheres) — LEGADO preservado
// ---------------------------------------------------------------------------

model Beneficiaria {
  id                       String   @id @default(uuid())
  codigoSGA                String?  @unique // ID SGA
  nis                      String?  @unique
  municipio                String?
  comunidade               String?
  ufpa                     String? // Unidade Familiar de Produção Agrária
  grupoInteresse           String?
  statusCadastro           String?
  situacaoProjeto          String?
  tipoAtendimento          String?
  atividadeProdutiva       String?
  projetoColetivoPrincipal String?
  valorProjetoATER         Decimal? @db.Decimal(15, 2)
  valorInvestidoUFPA       Decimal? @db.Decimal(15, 2)
  efetividade              String?
  houveAvanco              Boolean?
  sgaCadastro              Boolean?
  sgaRevisao               Boolean?
  sgaIndicador             Boolean?
  sgaFotos                 Boolean?
  statusSGA                String?
  ajusteProjeto            String?
  informacaoSGA            String?
  envioSGAPorAtividade     Json?

  cadastroId String        @unique
  cadastro   CadastroUnico @relation(fields: [cadastroId], references: [id])

  atendimentos     AtendimentoTecnico[]
  atendimentosATER Atendimento[]
  controleSGA      ControleProcessoSGA?
  fomento          Fomento?

  @@map("beneficiarias")
}

// ---------------------------------------------------------------------------
// 5b. ATER Socio — Família (novo módulo, orientado a família)
// ---------------------------------------------------------------------------

model FamiliaAter {
  id                       String   @id @default(uuid())
  nomeFamilia              String
  nomeResponsavel          String?
  documentoResponsavel     String? // CPF do responsável pela família
  telefone                 String?
  quantidadeMembros        Int?
  composicaoFamiliar       Json? // [{nome, parestesco, dataNascimento}]
  municipio                String?
  comunidade               String?
  enderecoUfpa             String?
  complementoUfpa          String?
  cepUfpa                  String?
  ufpa                     String? // Unidade Familiar de Produção Agrária
  dapCaf                   String?
  dapCafOrgaoEmissor       String?
  dapCafValidade           DateTime?
  areaEstabelecimento      Decimal? @db.Decimal(12, 2)
  areaImovelPrincipal      Decimal? @db.Decimal(12, 2)
  classificacaoUfpa        String?
  bioma                    String?
  latitude                 Decimal? @db.Decimal(10, 7)
  longitude                Decimal? @db.Decimal(10, 7)
  grupoInteresse           String?
  statusCadastro           String?
  situacaoProjeto          String?
  tipoAtendimento          String?
  atividadeProdutiva       String?
  projetoColetivoPrincipal String?
  programaFomento          String?
  valorProjetoATER         Decimal? @db.Decimal(15, 2)
  valorInvestidoUFPA       Decimal? @db.Decimal(15, 2)
  efetividade              String?
  houveAvanco              Boolean?
  nis                      String?
  codigoSGA                String?
  sgaCadastro              Boolean?
  sgaRevisao               Boolean?
  sgaIndicador             Boolean?
  sgaFotos                 Boolean?
  statusSGA                String?
  ajusteProjeto            String?
  informacaoSGA            String?
  envioSGAPorAtividade     Json?
  situacaoFomento          String?
  valorFomento             Decimal? @db.Decimal(15, 2)
  sgaStatusAnalise         String?
  sgaParcela1              String?
  sgaParcela2              String?
  sgaProjetoEnviado        Boolean  @default(false)
  dataEnvioSGA             DateTime?
  statusGestor             String?
  motivoReprovacaoGestor   String?  @db.Text
  dataStatusGestor         DateTime?
  organizacaoColetivaId    String?

  cadastroId String        @unique
  cadastro   CadastroUnico @relation(fields: [cadastroId], references: [id])

  organizacaoColetiva OrganizacaoColetiva? @relation(fields: [organizacaoColetivaId], references: [id], onDelete: SetNull)
  integrantes          IntegranteUfpa[]
  diagnostico          DiagnosticoUfpa?
  indicadores          IndicadoresUfpa?
  atendimentos         Atendimento[]

  @@index([organizacaoColetivaId])
  @@index([municipio])
  @@index([dapCaf])
  @@index([statusGestor])
  @@map("familias_ater")
}

model OrganizacaoColetiva {
  id                    String    @id @default(uuid())
  denominacao           String
  cnpj                  String?
  uf                    String?
  municipio             String?
  dataCadastro          DateTime?
  entidadeExecutoraNome String?
  entidadeExecutoraCnpj String?
  unidadeServicos       String?
  numeroInstrumento     String?
  agenteAterNome1       String?
  agenteAterCpf1        String?
  agenteAterNome2       String?
  agenteAterCpf2        String?
  agenteAterNome3       String?
  agenteAterCpf3        String?
  agenteAterNome4       String?
  agenteAterCpf4        String?
  numeroFamilias        Int?
  atividades            Json?
  grupoInteresse        String?
  observacoes           String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  familias    FamiliaAter[]
  indicadores IndicadoresOrganizacaoColetiva?

  @@index([denominacao])
  @@index([municipio])
  @@index([cnpj])
  @@map("organizacoes_coletivas")
}

model IntegranteUfpa {
  id               String    @id @default(uuid())
  cpf              String?
  nisCadUnico      String?
  nome             String
  apelido          String?
  sexo             String?
  orientacaoSexual String?
  identidadeGenero String?
  dataNascimento   DateTime?
  escolaridade     String?
  nomeMae          String?
  nomePai          String?
  classificacao    String?
  email            String?
  telefones        String?
  responsavelUfpa  Boolean   @default(false)
  parentesco       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  familiaId String
  familia   FamiliaAter @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@index([familiaId])
  @@index([cpf])
  @@index([nisCadUnico])
  @@map("integrantes_ufpa")
}

model DiagnosticoUfpa {
  id                        String    @id @default(uuid())
  entidadeExecutoraNome     String?
  entidadeExecutoraCnpj     String?
  unidadeServicos           String?
  numeroInstrumento         String?
  dataDiagnostico           DateTime?
  agenteAterNome1           String?
  agenteAterCpf1            String?
