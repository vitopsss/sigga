generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pessoa {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  tipo           String   @default("PF")
  documento      String   @unique
  nome           String
  email          String?
  telefone       String?
  endereco       String?
  bairro         String?
  cidade         String?
  estado         String?
  cep            String?
  pais           String?
  banco          String?
  agencia        String?
  conta          String?
  pix            String?
  origemCadastro String   @default("INTERNO")
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([documento])
  @@map("pessoas")
}

model CadastroUnico {
  id               String                 @id @default(uuid())
  nome             String
  documento        String                 @unique
  telefone         String?
  endereco         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  agencia          String?
  banco            String?
  conta            String?
  documentosAnexos Boolean                @default(false)
  email            String?
  origemCadastro   String                 @default("INTERNO")
  pix              String?
  tipo             TipoCadastro
  beneficiaria     Beneficiaria?
  colaborador      Colaborador?
  contratos        ContratoFornecedor[]
  empreendimento   Empreendimento?
  familia          FamiliaAter?
  borderos         LancamentoFinanceiro[]
  usuario          User?

  @@map("cadastros_unicos")
}

model User {
  id           String         @id @default(uuid())
  name         String?
  email        String?        @unique
  role         Role           @default(OPERADOR)
  cadastroId   String?        @unique
  passwordHash String?
  status       String         @default("ATIVO")
  perfilId     String?
  cadastro     CadastroUnico? @relation(fields: [cadastroId], references: [id])

  @@map("users")
}

model Projeto {
  id                 String                  @id @default(uuid())
  abreviacao         String?
  ano                Int?
  centroCusto        String                  @unique
  financiador        String?
  numContrato        String?
  portfolio          String?
  titulo             String
  valorTotal         Decimal                 @db.Decimal(15, 2)
  vigenciaFinal      DateTime?
  vigenciaInicial    DateTime
  status             String
  borderos           Bordero[]
  alocacoesRH        ColaboradorProjeto[]
  faturamentos       FaturamentoProjeto[]
  orcamentos         OrcamentoItem[]
  atividadesATER     PlanejamentoAtividade[]
  projetosProdutivos ProjetoProdutivo[]

  @@map("projetos")
}

model OrcamentoItem {
  id              String  @id @default(uuid())
  idOrc           String  @unique
  planoGerencial  String?
  descricao       String?
  unidade         String?
  quantidade      Int?
  valorReferencia Decimal @db.Decimal(15, 2)
  valorTotal      Decimal @db.Decimal(15, 2)
  projetoId       String
  projeto         Projeto @relation(fields: [projetoId], references: [id])

  @@map("orcamentos_itens")
}

model FaturamentoProjeto {
  id             String    @id @default(uuid())
  parcela        Int?
  vencimento     DateTime?
  valorTotal     Decimal   @db.Decimal(15, 2)
  dataLiquidacao DateTime?
  numNotaFiscal  String?
  projetoId      String
  projeto        Projeto   @relation(fields: [projetoId], references: [id])

  @@map("faturamentos_projetos")
}

model Bordero {
  id          String                 @id @default(uuid())
  status      String                 @default("Pendente")
  projetoId   String
  cadastrador String?
  data        DateTime?              @default(now())
  idBordero   String                 @unique
  tipoBordero String?
  projeto     Projeto                @relation(fields: [projetoId], references: [id])
  lancamentos LancamentoFinanceiro[]

  @@map("borderos")
}

model LancamentoFinanceiro {
  id             String        @id @default(uuid())
  nsu            String        @unique
  fase           String?
  etapa          String?
  atividade      String?
  valor          Decimal       @db.Decimal(15, 2)
  dataVencimento DateTime
  autorizado     Boolean       @default(false)
  conciliado     Boolean       @default(false)
  dataPagamento  DateTime?
  formaPagamento String?
  borderoId      String
  favorecidoId   String
  idOrc          String?
  idPgc          String?
  observacao     String?
  bordero        Bordero       @relation(fields: [borderoId], references: [id], onDelete: Cascade)
  favorecido     CadastroUnico @relation(fields: [favorecidoId], references: [id])

  @@map("lancamentos_financeiros")
}

model Colaborador {
  id          String               @id @default(uuid())
  cargo       String?
  salarioBase Decimal              @db.Decimal(15, 2)
  cadastroId  String               @unique
  idRH        String               @unique
  vinculo     String?
  status      String?
  cadastro    CadastroUnico        @relation(fields: [cadastroId], references: [id])
  alocacoes   ColaboradorProjeto[]

  @@map("colaboradores")
}

model ColaboradorProjeto {
  id            String      @id @default(uuid())
  porcentagem   Decimal     @default(100.00) @db.Decimal(5, 2)
  colaboradorId String
  projetoId     String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])
  projeto       Projeto     @relation(fields: [projetoId], references: [id])

  @@map("colaboradores_projetos")
}

model Beneficiaria {
  id                       String               @id @default(uuid())
  codigoSGA                String?              @unique
  nis                      String?              @unique
  municipio                String?
  comunidade               String?
  ufpa                     String?
  cadastroId               String               @unique
  grupoInteresse           String?
  statusCadastro           String?
  situacaoProjeto          String?
  tipoAtendimento          String?
  atividadeProdutiva       String?
  projetoColetivoPrincipal String?
  valorProjetoATER         Decimal?             @db.Decimal(15, 2)
  valorInvestidoUFPA       Decimal?             @db.Decimal(15, 2)
  efetividade              String?
  houveAvanco              Boolean?
  sgaCadastro              Boolean?
  sgaRevisao               Boolean?
  sgaIndicador             Boolean?
  sgaFotos                 Boolean?
  statusSGA                String?
  ajusteProjeto            String?
  informacaoSGA            String?
  envioSGAPorAtividade     Json?
  atendimentosATER         Atendimento[]
  atendimentos             AtendimentoTecnico[]
  cadastro                 CadastroUnico        @relation(fields: [cadastroId], references: [id])
  controleSGA              ControleProcessoSGA?
  fomento                  Fomento?

  @@map("beneficiarias")
}

model FamiliaAter {
  id                       String               @id @default(uuid())
  nomeFamilia              String
  nomeResponsavel          String?
  documentoResponsavel     String?
  telefone                 String?
  quantidadeMembros        Int?
  composicaoFamiliar       Json?
  municipio                String?
  comunidade               String?
  ufpa                     String?
  grupoInteresse           String?
  statusCadastro           String?
  situacaoProjeto          String?
  tipoAtendimento          String?
  atividadeProdutiva       String?
  projetoColetivoPrincipal String?
  valorProjetoATER         Decimal?             @db.Decimal(15, 2)
  valorInvestidoUFPA       Decimal?             @db.Decimal(15, 2)
  efetividade              String?
  houveAvanco              Boolean?
  nis                      String?
  codigoSGA                String?
  sgaCadastro              Boolean?
  sgaRevisao               Boolean?
  sgaIndicador             Boolean?
  sgaFotos                 Boolean?
  statusSGA                String?
  ajusteProjeto            String?
  informacaoSGA            String?
  envioSGAPorAtividade     Json?
  situacaoFomento          String?
  valorFomento             Decimal?             @db.Decimal(15, 2)
  sgaStatusAnalise         String?
  sgaParcela1              String?
  sgaParcela2              String?
  sgaProjetoEnviado        Boolean              @default(false)
  cadastroId               String               @unique
  enderecoUfpa             String?
  complementoUfpa          String?
  cepUfpa                  String?
  dapCaf                   String?
  dapCafOrgaoEmissor       String?
  dapCafValidade           DateTime?
  areaEstabelecimento      Decimal?             @db.Decimal(12, 2)
  areaImovelPrincipal      Decimal?             @db.Decimal(12, 2)
  classificacaoUfpa        String?
  bioma                    String?
  latitude                 Decimal?             @db.Decimal(10, 7)
  longitude                Decimal?             @db.Decimal(10, 7)
  programaFomento          String?
  dataEnvioSGA             DateTime?
  statusGestor             String?
  motivoReprovacaoGestor   String?
  dataStatusGestor         DateTime?
  organizacaoColetivaId    String?
  atendimentos             Atendimento[]

  projeto                  String?
  dataCadastro             DateTime?
  tecnico                  String?
  possuiRadio              Boolean?
  possuiTelevisao          Boolean?
  possuiCelular            Boolean?
  possuiInternet           Boolean?
  usaRedesSociais          Boolean?
  outroMeioComunicacao     String?
  possuiOutroMeioComunicacao Boolean?
  aguaParaConsumo          Boolean?
  aguaConsumoTratada       Boolean?
  aguaParaProducao         Boolean?
  captacaoAguaChuva        Boolean?
  esgotoTratado            Boolean?
  fontesProtegidas         Boolean?
  recursosDisponiveis      Json?
  atividadesColetivas      Json?
  politicasPublicas        Json?
  acoesPotenciaisProdutivo Json?
  acoesPotenciaisSocial    Json?
  acoesPotenciaisAmbiental Json?
  limitacoesProdutivo      Json?
  limitacoesSocial         Json?
  limitacoesAmbiental      Json?
  outrasAcoesPotenciais    String?
  outrasLimitacoes         String?
  lgpdConsentimento        Boolean?
  lgpdDataConsentimento    DateTime?
  representanteNome        String?
  representanteCpf         String?
  referenciaAnexoLgpd      String?
  anexoLgpdKey             String?
  anexoLgpdUrl             String?
  observacoes              String?
  patrimonios              Json?
  atividadesProdutivas     Json?

  cadastro                 CadastroUnico        @relation(fields: [cadastroId], references: [id])
  organizacaoColetiva      OrganizacaoColetiva? @relation(fields: [organizacaoColetivaId], references: [id])
  indicadores              IndicadoresUfpa?
  integrantes              IntegranteUfpa[]

  @@index([organizacaoColetivaId])
  @@index([municipio])
  @@index([dapCaf])
  @@index([statusGestor])
  @@map("familias_ater")
}

model OrganizacaoColetiva {
  id                    String                          @id @default(uuid())
  denominacao           String
  cnpj                  String?
  uf                    String?
  municipio             String?
  dataCadastro          DateTime?
  entidadeExecutoraNome String?
  entidadeExecutoraCnpj String?
  unidadeServicos       String?
  numeroInstrumento     String?
  numeroFamilias        Int?
  atividades            Json?
  grupoInteresse        String?
  observacoes           String?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  agenteAterCpf1        String?
  agenteAterCpf2        String?
  agenteAterCpf3        String?
  agenteAterCpf4        String?
  agenteAterNome1       String?
  agenteAterNome2       String?
  agenteAterNome3       String?
  agenteAterNome4       String?
  familias              FamiliaAter[]
  indicadores           IndicadoresOrganizacaoColetiva?

  @@index([denominacao])
  @@index([municipio])
  @@index([cnpj])
  @@map("organizacoes_coletivas")
}

model IntegranteUfpa {
  id               String      @id @default(uuid())
  cpf              String?
  nisCadUnico      String?
  nome             String
  apelido          String?
  sexo             String?
  orientacaoSexual String?
  identidadeGenero String?
  dataNascimento   DateTime?
  escolaridade     String?
  nomeMae          String?
  nomePai          String?
  classificacao    String?
  email            String?
  telefones        String?
  responsavelUfpa  Boolean     @default(false)
  parentesco       String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  familiaId        String
  familia          FamiliaAter @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@index([familiaId])
  @@index([cpf])
  @@index([nisCadUnico])
  @@map("integrantes_ufpa")
}


model IndicadoresUfpa {
  id                                    String      @id @default(uuid())
  projeto                               String?
  tecnico                               String?
  dataCadastro                          DateTime?
  dataReferencia                        DateTime?
  alimentacaoVariadaComprometida        Boolean?
  comidaAcabouSemCondicao               Boolean?
  deixouRefeicaoSemCondicao             Boolean?
  comeuMenosSemCondicao                 Boolean?
  qtdVezesComeuMenos                    Int?
  sentiuFomeENaoComeu                   Boolean?
  documentacaoPessoalCompleta           Boolean?
  cadastradoCadUnico                    Boolean?
  acessaPoliticasSociais                Boolean?
  politicasSociaisQuais                 String?
  participaGrupoComunitario             Boolean?
  qualGrupoComunitario                  String?
  participaAssociacao                   Boolean?
  participaCooperativa                  Boolean?
  participaGrupoInformalProdutivo       Boolean?
  participaGrupoInformalSocial          Boolean?
  possuiPraticasSustentaveis            Boolean?
  praticaIntegracaoAtividades           Boolean?
  praticaDescarteCorretoEmbalagens      Boolean?
  praticaControleQueimadas              Boolean?
  praticaAdubacaoVerde                  Boolean?
  praticaRecuperacaoPastagens           Boolean?
  praticaCoberturaSolo                  Boolean?
  praticaManejoIntegradoPragas          Boolean?
  praticaCordoesVegetacao               Boolean?
  praticaRotacaoCulturas                Boolean?
  praticaPlantioDireto                  Boolean?
  praticaPousio                         Boolean?
  praticaProtecaoNascentes              Boolean?
  praticaPreservacaoApps                Boolean?
  praticaManejoFlorestal                Boolean?
  praticaRecomposicaoFlorestal          Boolean?
  motivoSemPraticaFinanceiro            Boolean?
  motivoSemPraticaFaltaInformacao       Boolean?
  motivoSemPraticaTecnologico           Boolean?
  motivoSemPraticaFaltaInteresse        Boolean?
  valorBrutoProducaoUltimos12Meses      Decimal?    @db.Decimal(15, 2)
  acessaPoliticasProdutivas             Boolean?
  motivoNaoAcessaPoliticasFaltaInfo     Boolean?
  motivoNaoAcessaPoliticasDificilAcesso Boolean?
  motivoNaoAcessaPoliticasSemInteresse  Boolean?
  acessouPaa                            Boolean?
  acessouPnae                           Boolean?
  acessouPgpmBio                        Boolean?
  acessouPronaf                         Boolean?
  linhasPronaf                          Json?
  canalTrocaProdutoServico              Boolean?
  canalVendaPropriedade                 Boolean?
  canalVendaDiretaConsumidor            Boolean?
  canalFeira                            Boolean?
  canalMercadoLocal                     Boolean?
  canalAtravessador                     Boolean?
  canalPaa                              Boolean?
  canalPnae                             Boolean?
  canalCooperativaEntreposto            Boolean?
  observacoes                           String?
  createdAt                             DateTime    @default(now())
  updatedAt                             DateTime    @updatedAt
  familiaId                             String      @unique
  documentacaoPessoalQuais              String?
  cadUnicoQuais                         String?
  entidadeExecutoraNome                 String?
  entidadeExecutoraCnpj                 String?
  unidadeServicos                       String?
  numeroInstrumento                     String?
  agenteAterNome1                       String?
  agenteAterCpf1                        String?
  agenteAterNome2                       String?
  agenteAterCpf2                        String?
  agenteAterNome3                       String?
  agenteAterCpf3                        String?
  localUf                               String?
  localMunicipio                        String?
  localOrganizacaoColetiva              String?
  praticasSustentaveisQuais             String?
  familia                               FamiliaAter @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@index([alimentacaoVariadaComprometida])
  @@index([comidaAcabouSemCondicao])
  @@index([cadastradoCadUnico])
  @@index([acessaPoliticasSociais])
  @@index([acessaPoliticasProdutivas])
  @@map("indicadores_ufpa")
}

model IndicadoresOrganizacaoColetiva {
  id                                 String              @id @default(uuid())
  dataReferencia                     DateTime?
  possuiPraticasAmbientais           Boolean?
  praticaSeparacaoLixo               Boolean?
  praticaDescarteCorretoLixo         Boolean?
  praticaManutencaoAcessos           Boolean?
  praticaTratamentoDejetos           Boolean?
  praticaCaptacaoAguaChuva           Boolean?
  praticaEducacaoAmbiental           Boolean?
  praticaAvaliacaoPrevencaoRiscos    Boolean?
  usaIdentidadeComercial             Boolean?
  identidadeMarcaPropria             Boolean?
  identidadeSeloArte                 Boolean?
  identidadeSenaf                    Boolean?
  identidadeSenafSociobiodiversidade Boolean?
  identidadeSeloQuilombos            Boolean?
  identidadeSeloIndigenas            Boolean?
  identidadeSeloPovosTradicionais    Boolean?
  possuiMulheresDiretoriaConselho    Boolean?
  possuiJovensDiretoriaConselho      Boolean?
  filiadaOrganizacao                 Boolean?
  filiadaUnicafes                    Boolean?
  filiadaUnicopas                    Boolean?
  filiadaSistemaOcb                  Boolean?
  acessaPoliticasPublicas            Boolean?
  possuiCafJuridica                  Boolean?
  acessouPronafCusteio               Boolean?
  acessouPronafCapitalGiro           Boolean?
  acessouPronafMaisAlimentos         Boolean?
  acessouPronafIndustrializacao      Boolean?
  acessouPronafAgroindustria         Boolean?
  acessouPronafCotasPartes           Boolean?
  acessouPaa                         Boolean?
  acessouPnae                        Boolean?
  acessouPgpm                        Boolean?
  acessouPgpmSociobiodiversidade     Boolean?
  acessouCooperaMaisBrasil           Boolean?
  canalTrocaProdutoServico           Boolean?
  canalVendaOrganizacao              Boolean?
  canalVendaDiretaConsumidor         Boolean?
  canalFeira                         Boolean?
  canalMercadoLocal                  Boolean?
  canalAtravessador                  Boolean?
  canalPaa                           Boolean?
  canalPnae                          Boolean?
  canalMercadoJustoSolidario         Boolean?
  observacoes                        String?
  createdAt                          DateTime            @default(now())
  updatedAt                          DateTime            @updatedAt
  organizacaoColetivaId              String              @unique
  entidadeExecutoraNome              String?
  entidadeExecutoraCnpj              String?
  unidadeServicos                    String?
  numeroContrato                     String?
  agenteAterNome1                    String?
  agenteAterCpf1                     String?
  agenteAterNome2                    String?
  agenteAterCpf2                     String?
  agenteAterNome3                    String?
  agenteAterCpf3                     String?
  agenteAterNome4                    String?
  agenteAterCpf4                     String?
  localEstado                        String?
  localMunicipio                     String?
  localOrganizacaoColetiva           String?
  praticasAmbientaisQuais            String?
  identidadeComercialQuais           String?
  representacaoPoliticaQuais         String?
  politicasPublicasQuais             String?
  organizacaoColetiva                OrganizacaoColetiva @relation(fields: [organizacaoColetivaId], references: [id], onDelete: Cascade)

  @@index([possuiPraticasAmbientais])
  @@index([usaIdentidadeComercial])
  @@index([acessaPoliticasPublicas])
  @@map("indicadores_organizacoes_coletivas")
}

model AtendimentoTecnico {
  id               String       @id @default(uuid())
  idTec            String       @unique
  data             DateTime     @default(now())
  tecnico          String
  produtivoAcao    String?
  produtivoImpacto String?
  socialAcao       String?
  socialImpacto    String?
  ambientalAcao    String?
  ambientalImpacto String?
  beneficiariaId   String
  beneficiaria     Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("atendimentos_tecnicos")
}

model Atendimento {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numeroVisita           Int
  data                   DateTime?     @db.Timestamptz(6)
  tecnico                String?
  projetoId              String?
  projetoTitulo          String?
  statusRelatorio        String        @default("PENDENTE")
  houveAtendimento       Boolean?
  enviadoSGA             Boolean       @default(false)
  dataEnvioSGA           DateTime?     @db.Timestamptz(6)
  eixoProdutivo          Json?
  eixoSocial             Json?
  eixoAmbiental          Json?
  tecnicoId              String?
  beneficiariaId         String?
  familiaId              String?
  atividadeNumeroTotal   String?
  codigoMeta             String?
  descricaoMeta          String?
  numeroMulheres         Int?
  numeroJovens           Int?
  statusGestor           String?
  motivoReprovacaoGestor String?
  dataStatusGestor       DateTime?     @db.Timestamptz(6)
  beneficiaria           Beneficiaria? @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)
  familia                FamiliaAter?  @relation(fields: [familiaId], references: [id])
  tecnicoRef             Tecnico?      @relation(fields: [tecnicoId], references: [id])

  @@index([beneficiariaId], map: "atendimentos_beneficiaria_idx")
  @@index([numeroVisita])
  @@index([tecnicoId], map: "atendimentos_tecnico_idx")
  @@index([familiaId], map: "atendimentos_familia_idx")
  @@map("atendimentos")
}

model Tecnico {
  id               String        @id @default(dbgenerated("gen_random_uuid()"))
  nome             String
  cpf              String        @unique
  registroConselho String?
  uf               String?
  ativo            Boolean       @default(true)
  conselho         String?
  atendimentos     Atendimento[]

  @@index([cpf])
  @@map("tecnicos_ater")
}

model Fomento {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  situacao       String?
  valorFomento   Decimal?     @db.Decimal(15, 2)
  valorInvestido Decimal?     @db.Decimal(15, 2)
  retornoCampo   String?
  orientacoes    String?
  analiseAnater  String?
  beneficiariaId String       @unique
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id], onDelete: Cascade)

  @@index([beneficiariaId], map: "fomentos_beneficiaria_idx")
  @@map("fomentos")
}

model ControleProcessoSGA {
  id             String       @id @default(uuid())
  statusAnalise  String?
  parcela1       String?
  parcela2       String?
  projetoEnviado Boolean      @default(false)
  beneficiariaId String       @unique
  beneficiaria   Beneficiaria @relation(fields: [beneficiariaId], references: [id])

  @@map("controle_sga")
}

model PlanejamentoAtividade {
  id            String  @id @default(uuid())
  numMeta       Int
  descricao     String
  status        String
  valorUnitario Decimal @db.Decimal(15, 2)
  projetoId     String
  projeto       Projeto @relation(fields: [projetoId], references: [id])

  @@map("planejamento_ater")
}

model ProjetoProdutivo {
  id        String  @id @default(uuid())
  atividade String
  situacao  String?
  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id])

  @@map("projetos_produtivos")
}

model ContratoFornecedor {
  id           String        @id @default(uuid())
  idContrato   String        @unique
  objeto       String?
  valorTotal   Decimal       @db.Decimal(15, 2)
  status       String?
  fornecedorId String
  fornecedor   CadastroUnico @relation(fields: [fornecedorId], references: [id])

  @@map("contratos_fornecedores")
}

model Patrimonio {
  id             String   @id @default(uuid())
  tombamento     String?  @unique
  descricao      String
  status         String?
  valorAquisicao Decimal? @db.Decimal(15, 2)

  @@map("patrimonio")
}

model Empreendimento {
  id            String              @id @default(uuid())
  matricula     String?             @unique
  nome          String
  segmento      String?
  status        String?             @default("ATIVO")
  cadastroId    String              @unique
  contribuicoes ContribuicaoFundo[]
  cadastro      CadastroUnico       @relation(fields: [cadastroId], references: [id])

  @@map("empreendimentos")
}

model ContribuicaoFundo {
  id               String         @id @default(uuid())
  parcela          String?
  mesReferencia    Int?
  anoReferencia    Int?
  valorGerado      Decimal        @db.Decimal(15, 2)
  valorPago        Decimal?       @db.Decimal(15, 2)
  dataVencimento   DateTime?
  dataPagamento    DateTime?
  status           String         @default("PENDENTE")
  empreendimentoId String
  empreendimento   Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@map("contribuicoes_fundo")
}

enum Role {
  ADMINISTRADOR_DIRETOR
  GERENTE
  COORDENADOR_PROJETO
  OPERADOR
}

enum TipoCadastro {
  PF
  PJ
  PUBLICO
  PRIVADO
}
