  familiaId String      @unique
  familia   FamiliaAter @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@index([aguaParaConsumo])
  @@index([aguaConsumoTratada])
  @@index([possuiInternet])
  @@index([esgotoTratado])
  @@map("diagnosticos_ufpa")
